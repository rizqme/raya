/** Iterator pragmatic subset */

export class IteratorResult<T> {
    value: T | null;
    done: boolean;
    constructor(value: T | null, done: boolean);
}

export class Iterator<T> {
    constructor(values: T[]);

    static fromArray<U>(values: U[]): Iterator<U>;
    next(): IteratorResult<T>;
    toArray(): T[];
}
