// Node-compat function/generator constructor families.
// Pragmatic subset: compile-visible surface with unimplemented runtime behavior.

const FUNCTION_CALL_HELPER: number = 0x000E;
const FUNCTION_APPLY_HELPER: number = 0x000F;
const FUNCTION_BIND_HELPER: number = 0x0010;
const FUNCTION_CONSTRUCTOR_HELPER: number = 0x0012;
const OBJECT_GENERATOR_NEXT: number = 0x0045;
const OBJECT_GENERATOR_RETURN: number = 0x0046;

class Function {
    constructor(...parts: any[]) {
        return __NATIVE_CALL<any>(FUNCTION_CONSTRUCTOR_HELPER, parts);
    }

    call(thisArg: any, ...args: any[]): any {
        return __NATIVE_CALL<any>(FUNCTION_CALL_HELPER, this, thisArg, args);
    }

    apply(thisArg: any, args: any = undefined): any {
        return __NATIVE_CALL<any>(FUNCTION_APPLY_HELPER, this, thisArg, args);
    }

    bind(thisArg: any, ...args: any[]): any {
        return __NATIVE_CALL<any>(FUNCTION_BIND_HELPER, this, thisArg, args);
    }
}

function __throwTypeErrorAccessor(): any {
    throw new TypeError("Restricted function property access");
}

Object.defineProperty(
    (Function as any).prototype,
    "caller",
    {
        get: __throwTypeErrorAccessor,
        set: __throwTypeErrorAccessor,
        enumerable: false,
        configurable: true,
    },
);

Object.defineProperty(
    (Function as any).prototype,
    "arguments",
    {
        get: __throwTypeErrorAccessor,
        set: __throwTypeErrorAccessor,
        enumerable: false,
        configurable: true,
    },
);

export {
    Function,
    AsyncFunction,
    Generator,
    AsyncGenerator,
    GeneratorFunction,
    AsyncGeneratorFunction,
    AsyncIterator,
};

class AsyncFunction extends Function {
    constructor(body: string) {
        super(body);
    }
}

class Generator {
    constructor() {}
}

class AsyncGenerator {
    constructor() {}

    next(value: any = undefined): Promise<any> {
        return __NATIVE_CALL<any>(OBJECT_GENERATOR_NEXT, this, value);
    }

    return(value: any = undefined): Promise<any> {
        return __NATIVE_CALL<any>(OBJECT_GENERATOR_RETURN, this, value);
    }

    __asyncIteratorObject(): any {
        return this;
    }
}

class GeneratorFunction extends Function {
    constructor(body: string) {
        super(body);
    }
}

class AsyncGeneratorFunction extends Function {
    constructor(body: string) {
        super(body);
    }
}

Object.setPrototypeOf(
    (AsyncFunction as any).prototype,
    (Function as any).prototype,
);

Object.setPrototypeOf(
    (GeneratorFunction as any).prototype,
    (Function as any).prototype,
);

Object.setPrototypeOf(
    (AsyncGeneratorFunction as any).prototype,
    (Function as any).prototype,
);

Object.defineProperty(
    (GeneratorFunction as any).prototype,
    "prototype",
    {
        value: (Generator as any).prototype,
        writable: false,
        enumerable: false,
        configurable: false,
    },
);

Object.defineProperty(
    (AsyncGeneratorFunction as any).prototype,
    "prototype",
    {
        value: (AsyncGenerator as any).prototype,
        writable: false,
        enumerable: false,
        configurable: false,
    },
);

class AsyncIterator<T> {
    constructor() {}

    async next(): Promise<IteratorResult<T> > {
        throw createError(E_UNIMPLEMENTED_BUILTIN_BEHAVIOR, "AsyncIterator.next is not implemented in node-compat runtime yet");
    }
}
