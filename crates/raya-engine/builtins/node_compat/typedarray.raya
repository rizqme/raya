function __typedArraySourceValues(source: any): any[] {
    let iteratorMethod = source[Symbol.iterator];
    if (iteratorMethod != null) {
        if (typeof iteratorMethod != "function") {
            throw new TypeError("TypedArray source iterator is not callable");
        }
        let iterator = iteratorMethod.call(source);
        if (iterator == null || typeof iterator != "object") {
            throw new TypeError("TypedArray source iterator is not an object");
        }
        let nextMethod = iterator["next"];
        if (typeof nextMethod != "function") {
            throw new TypeError("TypedArray source next is not callable");
