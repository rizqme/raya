class BigInt64Array {
    // Pragmatic subset: values are represented as number.
    _fixedLength: int;
    _lengthTracking: boolean;
    static BYTES_PER_ELEMENT: int = 8;
    buffer: ArrayBuffer;
    byteOffset: int;
    byteLength: int;
    length: int;

    constructor(source: any, byteOffset: any = 0, length: any = -1) {
