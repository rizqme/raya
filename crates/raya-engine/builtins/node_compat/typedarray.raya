    set(index: int, value: number): void {
        this._f64.set(index, value);
    }
}

class BigInt64Array {
    // Pragmatic subset: values are represented as number.
    private _f64: Float64Array;
    byteOffset: int;
    byteLength: int;
    length: int;

    constructor(source: Object | number, byteOffset: int = 0, length: int = -1) {
        this._f64 = new Float64Array(source, byteOffset, length);
        this.byteOffset = this._f64.byteOffset;
        this.byteLength = this._f64.byteLength;
        this.length = this._f64.length;
    }

    get(index: int): number {
        return this._f64.get(index);
    }

    set(index: int, value: number): void {
        this._f64.set(index, value);
    }
}

class BigUint64Array {
    // Pragmatic subset: values are represented as number.
    private _f64: Float64Array;
    byteOffset: int;
    byteLength: int;
    length: int;

    constructor(source: Object | number, byteOffset: int = 0, length: int = -1) {
        this._f64 = new Float64Array(source, byteOffset, length);
        this.byteOffset = this._f64.byteOffset;
        this.byteLength = this._f64.byteLength;
        this.length = this._f64.length;
    }

    get(index: int): number {
        return this._f64.get(index);
    }

    set(index: int, value: number): void {
        this._f64.set(index, value);
    }
}

class TypedArray<T> {
    // Global TypedArray surface for compatibility checks.
    byteOffset: int;
    byteLength: int;
    length: int;

    constructor(source: Object | number = 0, _byteOffset: int = 0, _length: int = -1) {
        let sourceType = typeof source;
        if (sourceType == "int" || sourceType == "number") {
            let n = source as int;
            if (n < 0) {
                throw createRangeError(ERR_OUT_OF_RANGE, "TypedArray length must be >= 0");
            }
            this.length = n;
        } else {
            let ab = source as ArrayBuffer;
            this.length = ab.byteLength;
        }
        this.byteOffset = 0;
        this.byteLength = this.length;
    }
}
