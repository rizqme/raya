// TypedArray and ArrayBuffer builtins
// Node-like surface for Raya strict numeric model (int indices/lengths).

const JS_TO_NUMBER: number = 0x001D;
const JS_TO_INTEGER_OR_INFINITY: number = 0x001E;
const __FLOAT32_NAN_SENTINEL: int = -2147483648;
const __FLOAT32_POSITIVE_INFINITY_SENTINEL: int = -2147483647;
const __FLOAT32_NEGATIVE_INFINITY_SENTINEL: int = -2147483646;
const __FLOAT16_NAN_SENTINEL: int = 65535;
const __FLOAT16_POSITIVE_INFINITY_SENTINEL: int = 65534;
const __FLOAT16_NEGATIVE_INFINITY_SENTINEL: int = 65533;
const __POSITIVE_INFINITY: number = 1.0 / 0.0;
const __NEGATIVE_INFINITY: number = -__POSITIVE_INFINITY;
const __NaN: number = 0.0 / 0.0;

function typedArrayJsToNumber(value: any): number {
    return __NATIVE_CALL<number>(JS_TO_NUMBER, value);
}

function typedArrayJsToIntegerOrInfinity(value: any): number {
    return __NATIVE_CALL<number>(JS_TO_INTEGER_OR_INFINITY, value);
}

function __typedArrayIntegerElementValue(value: any): int {
    let numeric = typedArrayJsToNumber(value);
    if (numeric != numeric || numeric == __POSITIVE_INFINITY || numeric == __NEGATIVE_INFINITY) {
        return 0;
    }
    return numeric as int;
}

function __typedArrayFloat32StoredValue(value: any): int {
    let numeric = typedArrayJsToIntegerOrInfinity(value);
    if (numeric != numeric) {
        return __FLOAT32_NAN_SENTINEL;
    }
    if (numeric == __POSITIVE_INFINITY) {
        return __FLOAT32_POSITIVE_INFINITY_SENTINEL;
    }
    if (numeric == __NEGATIVE_INFINITY) {
        return __FLOAT32_NEGATIVE_INFINITY_SENTINEL;
    }
    return numeric as int;
}

function __typedArrayDecodeFloat32StoredValue(raw: int): number {
    if (raw == __FLOAT32_NAN_SENTINEL) {
        return __NaN;
    }
    if (raw == __FLOAT32_POSITIVE_INFINITY_SENTINEL) {
        return __POSITIVE_INFINITY;
    }
    if (raw == __FLOAT32_NEGATIVE_INFINITY_SENTINEL) {
        return __NEGATIVE_INFINITY;
    }
    return raw as number;
}

function __typedArrayFloat16StoredValue(value: any): int {
    let numeric = typedArrayJsToIntegerOrInfinity(value);
    if (numeric != numeric) {
        return __FLOAT16_NAN_SENTINEL;
    }
    if (numeric == __POSITIVE_INFINITY) {
        return __FLOAT16_POSITIVE_INFINITY_SENTINEL;
    }
    if (numeric == __NEGATIVE_INFINITY) {
        return __FLOAT16_NEGATIVE_INFINITY_SENTINEL;
    }
    return numeric as int;
}

function __typedArrayDecodeFloat16StoredValue(raw: int): number {
    if (raw == __FLOAT16_NAN_SENTINEL) {
        return __NaN;
    }
    if (raw == __FLOAT16_POSITIVE_INFINITY_SENTINEL) {
        return __POSITIVE_INFINITY;
    }
    if (raw == __FLOAT16_NEGATIVE_INFINITY_SENTINEL) {
        return __NEGATIVE_INFINITY;
    }
    return raw as number;
}

class ArrayBuffer {
    private _bytes: int[];
    private _detached: boolean;
    byteLength: int;
    maxByteLength: int;
    resizable: boolean;

    constructor(byteLength: int = 0, options: any = null) {
        if (byteLength < 0) {
            throw createRangeError(ERR_OUT_OF_RANGE, "ArrayBuffer length must be >= 0");
        }
        let maxByteLength = byteLength;
        let hasMaxByteLengthOption = false;
        if (options != null) {
            let dynOptions = options as any;
            if (dynOptions["maxByteLength"] != null) {
                maxByteLength = dynOptions["maxByteLength"] as int;
                hasMaxByteLengthOption = true;
            }
        }
        if (maxByteLength < byteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "maxByteLength must be >= byteLength");
        }
        this.byteLength = byteLength;
        this.maxByteLength = maxByteLength;
        this.resizable = hasMaxByteLengthOption;
        this._detached = false;
        this._bytes = [];
        let i = 0;
        while (i < byteLength) {
            this._bytes.push(0);
            i = i + 1;
        }
    }

    private _checkByteOffset(offset: int): void {
        if (offset < 0 || offset >= this.byteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "Offset out of range");
        }
    }

    getByte(offset: int): int {
        this._checkByteOffset(offset);
        return this._bytes[offset];
    }

    setByte(offset: int, value: int): void {
        this._checkByteOffset(offset);
        let out = value % 256;
        if (out < 0) {
            out = out + 256;
        }
        this._bytes[offset] = out;
    }

    getInt32(offset: int): int {
        if (offset < 0 || (offset + 4) > this.byteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "Offset out of range");
        }
        let b0 = this._bytes[offset];
        let b1 = this._bytes[offset + 1];
        let b2 = this._bytes[offset + 2];
        let b3 = this._bytes[offset + 3];
        return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24);
    }

    setInt32(offset: int, value: int): void {
        if (offset < 0 || (offset + 4) > this.byteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "Offset out of range");
        }
        this._bytes[offset] = value & 255;
        this._bytes[offset + 1] = (value >> 8) & 255;
        this._bytes[offset + 2] = (value >> 16) & 255;
        this._bytes[offset + 3] = (value >> 24) & 255;
    }

    getFloat64(offset: int): number {
        if (offset < 0 || (offset + 8) > this.byteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "Offset out of range");
        }
        let tmp = new Buffer(8);
        let i = 0;
        while (i < 8) {
            tmp.setByte(i, this._bytes[offset + i]);
            i = i + 1;
        }
        return tmp.getFloat64(0);
    }

    setFloat64(offset: int, value: number): void {
        if (offset < 0 || (offset + 8) > this.byteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "Offset out of range");
        }
        let tmp = new Buffer(8);
        tmp.setFloat64(0, value);
        let i = 0;
        while (i < 8) {
            this._bytes[offset + i] = tmp.getByte(i);
            i = i + 1;
        }
    }

    rawBuffer(): Buffer {
        let out = new Buffer(this.byteLength);
        let i = 0;
        while (i < this.byteLength) {
            out.setByte(i, this._bytes[i]);
            i = i + 1;
        }
        return out;
    }

    isDetached(): boolean {
        return this._detached;
    }

    detach(): void {
        this._detached = true;
        this._bytes = [];
        this.byteLength = 0;
        this.maxByteLength = 0;
        this.resizable = false;
    }

    slice(begin: int = 0, end: int = -1): ArrayBuffer {
        let start = begin;
        if (start < 0) {
            start = this.byteLength + start;
        }
        if (start < 0) {
            start = 0;
        }

        let finish = end;
        if (finish < 0) {
            finish = this.byteLength + finish;
        }
        if (finish < 0 || end == -1) {
            finish = this.byteLength;
        }
        if (finish > this.byteLength) {
            finish = this.byteLength;
        }
        if (finish < start) {
            finish = start;
        }

        let outLen = finish - start;
        let out = new ArrayBuffer(outLen);
        let i = 0;
        while (i < outLen) {
            out.setByte(i, this._bytes[start + i]);
            i = i + 1;
        }
        return out;
    }

    resize(newByteLength: int): void {
        if (!this.resizable) {
            throw createRangeError(ERR_OUT_OF_RANGE, "ArrayBuffer is not resizable");
        }
        if (newByteLength < 0 || newByteLength > this.maxByteLength) {
            throw createRangeError(ERR_OUT_OF_RANGE, "new byteLength out of range");
        }

        if (newByteLength > this.byteLength) {
            let i = this.byteLength;
            while (i < newByteLength) {
                this._bytes.push(0);
                i = i + 1;
            }
        } else if (newByteLength < this.byteLength) {
            let next: int[] = [];
            let i = 0;
            while (i < newByteLength) {
                next.push(this._bytes[i]);
                i = i + 1;
            }
            this._bytes = next;
        }

        this.byteLength = newByteLength;
    }

    asArrayBuffer(): ArrayBuffer {
        return this;
    }
}

function __coerceObjectToArrayBuffer(source: any): ArrayBuffer {
    let dynSource = source as any;
    if (dynSource.asArrayBuffer != null) {
        return dynSource.asArrayBuffer() as ArrayBuffer;
    }
    return source as ArrayBuffer;
}

function __typedArrayIsArrayBufferSource(source: any): boolean {
    if (source == null) {
        return false;
    }
    if (source instanceof ArrayBuffer) {
        return true;
    }
    let dynSource = source as any;
    return dynSource.asArrayBuffer != null || dynSource.resize != null || dynSource.maxByteLength != null;
